          "informationUri": "https://github.com/anchore/grype",
          "rules": [
            {
              "id": "GHSA-5rjg-fvgr-3xxf-setuptools",
              "name": "PythonMatcherExactDirectMatch",
              "shortDescription": {
                "text": "GHSA-5rjg-fvgr-3xxf high vulnerability for setuptools package"
              },
              "fullDescription": {
                "text": "setuptools has a path traversal vulnerability in PackageIndex.download that leads to Arbitrary File Write"
              },
              "helpUri": "https://github.com/anchore/grype",
              "help": {
                "text": "Vulnerability GHSA-5rjg-fvgr-3xxf\nSeverity: high\nPackage: setuptools\nVersion: 70.2.0\nFix Version: 78.1.1\nType: python\nLocation: /tavus-pipecat-example/env/lib/python3.13/site-packages/setuptools-70.2.0.dist-info/METADATA\nData Namespace: github:language:python\nLink: [GHSA-5rjg-fvgr-3xxf](https://github.com/advisories/GHSA-5rjg-fvgr-3xxf)",
                "markdown": "**Vulnerability GHSA-5rjg-fvgr-3xxf**\n| Severity | Package | Version | Fix Version | Type | Location | Data Namespace | Link |\n| --- | --- | --- | --- | --- | --- | --- | --- |\n| high  | setuptools  | 70.2.0  | 78.1.1  | python  | /tavus-pipecat-example/env/lib/python3.13/site-packages/setuptools-70.2.0.dist-info/METADATA  | github:language:python  | [GHSA-5rjg-fvgr-3xxf](https://github.com/advisories/GHSA-5rjg-fvgr-3xxf)  |\n"
              },
              "properties": {
                "purls": [
                  "pkg:pypi/setuptools@70.2.0"
                ],
                "security-severity": "7.7"
              }
            },
            {
