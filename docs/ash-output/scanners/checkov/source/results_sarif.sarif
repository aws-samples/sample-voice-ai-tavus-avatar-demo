   - ErrorCode: 404\n            ResponseCode: 200\n            ResponsePagePath: /index.html\n"}}}}]}, {"ruleId": "CKV_DOCKER_3", "ruleIndex": 19, "level": "error", "attachments": [], "message": {"text": "Ensure that a user for the container has been created"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "tavus-pipecat-example/Dockerfile"}, "region": {"startLine": 1, "endLine": 17, "snippet": {"text": "FROM python:3.13-slim\n\nWORKDIR /app/tavus-pipecat-example\n\n# Install dependencies first for better layer caching\nCOPY tavus-pipecat-example/requirements.txt .\nRUN pip install --no-cache-dir -r requirements.txt\n\n# Copy application code\nCOPY tavus-pipecat-example/tavus-pipecat.py .\n\n# Copy shared prompts (tavus-pipecat.py reads from ../prompts/)\nCOPY prompts/ /app/prompts/\n\nEXPOSE 7860\n\nCMD [\"python\", \"tavus-pipecat.py\", \"--transport\", \"daily\", \"--host\", \"0.0.0.0\", \"--port\", \"7860\"]"}}}}]}, {"ruleId": "CKV_DOCKER_2", "ruleIndex": 20, "level": "error", "attachments": [], "message": {"text": "Ensure that HEALTHCHECK instructions have been added to container images"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "tavus-pipecat-example/Dockerfile"}, "region": {"startLine": 1, "endLine": 17, "snippet": {"text": "FROM python:3.13-slim\n\nWORKDIR /app/tavus-pipecat-example\n\n# Install dependencies first for better layer caching\nCOPY tavus-pipecat-example/requirements.txt .\nRUN pip install --no-cache-dir -r requirements.txt\n\n# Copy application code\nCOPY tavus-pipecat-example/tavus-pipecat.py .\n\n# Copy shared prompts (tavus-pipecat.py reads from ../prompts/)\nCOPY prompts/ /app/prompts/\n\nEXPOSE 7860\n\nCMD [\"python\", \"tavus-pipecat.py\", \"--transport\", \"daily\", \"--host\", \"0.0.0.0\", \"--port\", \"7860\"]"}}}}]}, {"ruleId": "CKV_SECRET_6", "ruleIndex": 21, "level": "error", "attachments": [], "message": {"text": "Base64 High Entropy String"}, "locations": [{"physicalLocation": {"artifactLo